<Window x:Class="EnterpriseChatBot.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EnterpriseChatBot.Desktop"
        xmlns:vm="clr-namespace:EnterpriseChatBot.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="Enterprise Chat Bot"
        Height="650"
        Width="1000">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#F4F4F4">
            <TextBlock Text="Чаты"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="12"/>

            <Button Content="Новый чат"
                    Height="40"
                    Margin="12,0,12,8"
                    Command="{Binding NewChatCommand}" />

            <Button Content="Загрузить файл"
                    Height="40"
                    Margin="12,0,12,12"
                    Command="{Binding LoadFileCommand}" />

            <ListBox ItemsSource="{Binding Chats}"
                     SelectedItem="{Binding SelectedChat}"
                     DisplayMemberPath="Title"
                     Margin="12"
                     Height="500"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            
                <Border Grid.Row="0"
        BorderThickness="1"
        BorderBrush="LightGray"
        CornerRadius="8"
        Padding="10">
                    <ListBox ItemsSource="{Binding Messages}"
             FontSize="16"
             HorizontalContentAlignment="Stretch"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                        Padding="10"
                        Background="#F5F5F5"
                        CornerRadius="8"
                        HorizontalAlignment="Stretch">
                                    <TextBlock Text="{Binding}"
                               TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
           

            <DockPanel Grid.Row="1" Margin="0,10,0,0">
                <TextBox Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"/>

                <Button Content="Отправить"
                        Width="130"
                        Height="40"
                        Command="{Binding SendMessageCommand}"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
