<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EnterpriseChatBot.Mobile.Pages.ChatListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:EnterpriseChatBot.Mobile.Models"
    Title="Чаты">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Выход" Clicked="OnLogoutClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label
                x:Name="WelcomeLabel"
                Text="Список чатов"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="{StaticResource TextColor}" />

            <Label
                Text="Все диалоги в одном месте"
                FontSize="14"
                TextColor="{StaticResource HintColor}" />
        </VerticalStackLayout>

        <Button
            Grid.Row="1"
            Text="Новый чат"
            Style="{StaticResource PrimaryButtonStyle}"
            Clicked="OnCreateChatClicked" />

        <CollectionView
            x:Name="ChatsCollection"
            Grid.Row="2"
            SelectionMode="Single"
            SelectionChanged="OnChatSelected">

            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="20" Spacing="8">
                    <Label
                        Text="Чатов пока нет"
                        HorizontalTextAlignment="Center"
                        FontSize="18"
                        FontAttributes="Bold" />
                    <Label
                        Text="Создай первый чат кнопкой выше"
                        HorizontalTextAlignment="Center"
                        TextColor="{StaticResource HintColor}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatSessionItem">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <SwipeItem
                                    Text="Удалить"
                                    BackgroundColor="IndianRed"
                                    Invoked="OnDeleteChatInvoked"
                                    CommandParameter="{Binding Id}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border
                            Margin="0,0,0,10"
                            BackgroundColor="White"
                            Stroke="{StaticResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 20"
                            Padding="16">
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                <Label
                                    Text="{Binding Title}"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextColor}" />

                                <Label
                                    Grid.Row="1"
                                    Text="{Binding LastMessage}"
                                    FontSize="13"
                                    MaxLines="2"
                                    LineBreakMode="TailTruncation"
                                    TextColor="{StaticResource HintColor}" />

                                <Label
                                    Grid.Row="2"
                                    Text="{Binding CreatedAtText}"
                                    FontSize="11"
                                    TextColor="{StaticResource HintColor}" />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>