<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EnterpriseChatBot.Mobile.Pages.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Регистрация"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" Padding="24,32,24,24">

        <VerticalStackLayout Spacing="8">
            <Border
                BackgroundColor="{StaticResource PrimaryColor}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20"
                WidthRequest="64"
                HeightRequest="64"
                HorizontalOptions="Start">
                <Label
                    Text="👤"
                    FontSize="28"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>

            <Label
                Text="Создание аккаунта"
                Style="{StaticResource PageTitleStyle}" />

            <Label
                Text="Зарегистрируйтесь для продолжения"
                Style="{StaticResource PageSubtitleStyle}" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="18" VerticalOptions="Center">

                <Border
                    BackgroundColor="{StaticResource CardColor}"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24"
                    Padding="20">

                    <VerticalStackLayout Spacing="16">

                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Имя"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextColor}" />
                            <Border
                                BackgroundColor="{StaticResource SecondaryColor}"
                                Stroke="{StaticResource BorderColor}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="14,6">
                                <Entry
                                    x:Name="NameEntry"
                                    Placeholder="Введите имя" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Email"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextColor}" />
                            <Border
                                BackgroundColor="{StaticResource SecondaryColor}"
                                Stroke="{StaticResource BorderColor}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="14,6">
                                <Entry
                                    x:Name="EmailEntry"
                                    Placeholder="Введите email"
                                    Keyboard="Email" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="Пароль"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextColor}" />
                            <Border
                                BackgroundColor="{StaticResource SecondaryColor}"
                                Stroke="{StaticResource BorderColor}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 16"
                                Padding="14,6">
                                <Entry
                                    x:Name="PasswordEntry"
                                    Placeholder="Введите пароль"
                                    IsPassword="True" />
                            </Border>
                        </VerticalStackLayout>

                        <Button
                            Text="Зарегистрироваться"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Clicked="OnRegisterClicked" />

                        <Button
                            Text="Назад"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Clicked="OnBackClicked" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>