<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EnterpriseChatBot.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:EnterpriseChatBot.Mobile.Pages"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Login"
            Route="LoginPage"
            ContentTemplate="{DataTemplate pages:LoginPage}" />

        <ShellContent
            Title="Chats"
            Route="ChatListPage"
            ContentTemplate="{DataTemplate pages:ChatListPage}" />
    </TabBar>
</Shell>
